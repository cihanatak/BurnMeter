{
  "name": "burnmeter",
  "productName": "Burnmeter",
  "version": "0.2.1",
  "description": "Burnmeter desktop (Electron shell over the Python sidecar)",
  "main": "main.js",
  "author": "Cihan Atak",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.burnmeter.app",
    "productName": "Burnmeter",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "package.json"],
    "extraResources": [
      { "from": "../dist/burnmeter-server", "to": "server" },
      { "from": "../burnmeter/assets/burnmeter.png", "to": "burnmeter.png" },
      { "from": "../burnmeter/assets/burnmeter.ico", "to": "burnmeter.ico" }
    ],
    "win": {
      "icon": "../burnmeter/assets/burnmeter.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "BurnmeterSetup-electron-${version}.${ext}"
    },
    "mac": {
      "icon": "../burnmeter/assets/burnmeter.png",
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    }
  }
}
